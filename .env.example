# zotero2ai local development environment
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --------------------------------------------------------------------------
# Required: Zotero HTTP Bridge token
# Generate in Zotero → Edit → Preferences → MCP Bridge → Generate Token
# --------------------------------------------------------------------------
ZOTERO_MCP_TOKEN=your_token_here

# --------------------------------------------------------------------------
# Optional: Override Zotero data directory
# Default: auto-detected from ~/Zotero or ~/zotero
# --------------------------------------------------------------------------
# ZOTERO_DATA_DIR=/Users/yourname/Zotero

# --------------------------------------------------------------------------
# Optional: Override bridge port (default: 23120)
# --------------------------------------------------------------------------
# ZOTERO_BRIDGE_PORT=23120

# --------------------------------------------------------------------------
# Optional: SSE server settings (for make serve-sse)
# --------------------------------------------------------------------------
# SSE_HOST=127.0.0.1
# SSE_PORT=8765
