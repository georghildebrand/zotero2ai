{
    "mcpServers": {
        "zotero2ai": {
            "command": "uv",
            "args": [
                "--directory",
                "[PATH_TO_REPO]",
                "run",
                "mcp-zotero2ai",
                "run"
            ],
            "env": {
                "ZOTERO_DATA_DIR": "[PATH_TO_ZOTERO_DATA]",
                "ZOTERO_BRIDGE_PORT": "23120",
                "ZOTERO_MCP_TOKEN": "[YOUR_TOKEN]",
                "PATH": "[PATH_TO_UV_BIN]:$PATH"
            }
        }
    }
}